# Doom in a browser, served from a hardware-isolated microVM
#
# Sandbox:
#   smolvm machine run -d -s examples/doom-web/doom.smolfile
#   open http://localhost:8080

image = "python:3.12-alpine"
entrypoint = ["python3"]
cmd = ["-m", "http.server", "8080", "--directory", "/var/www"]

cpus = 2
memory = 512
net = true

[service]
listen = 8080
protocol = "http"

[dev]
volumes = ["./examples/doom-web:/var/www"]
ports = ["8080:8080"]
